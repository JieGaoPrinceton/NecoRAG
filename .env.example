# ======================================
# NecoRAG 开发环境变量配置示例
# Development Environment Variables
# ======================================
# 使用说明:
# 1. 复制此文件为 .env
#    cp .env.example .env
# 2. 修改为你的实际配置
# 3. .env 文件已被 .gitignore 忽略，可安全存放敏感信息
#
# Last Updated: 2026-03-19
# Version: 2.0.0-alpha
# ======================================

# ============================================
# 🐍 Python 环境配置
# ============================================
PYTHON_VERSION=3.11.8
VIRTUAL_ENV=.venv

# ============================================
# 🌐 应用基础配置
# ============================================
APP_ENV=development
# APP_ENV=production

APP_DEBUG=true
# APP_DEBUG=false

APP_HOST=127.0.0.1
APP_PORT=8000

LOG_LEVEL=INFO
# LOG_LEVEL=DEBUG
# LOG_LEVEL=WARNING
# LOG_LEVEL=ERROR

# ============================================
# 💾 数据库配置
# ============================================

# Redis (工作记忆与缓存)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
# REDIS_URL=redis://localhost:6379/0

# Qdrant (向量数据库)
QDRANT_HOST=localhost
QDRANT_PORT=6334
QDRANT_GRPC_PORT=6333
QDRANT_API_KEY=
# QDRANT_URL=http://localhost:6334

# Neo4j (图数据库)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=necorag2026
NEO4J_DATABASE=neo4j

# ============================================
# 🤖 LLM 配置
# ============================================

# LLM 提供商选择
# 可选值：mock, openai, ollama, qwen, moonshot 等
LLM_PROVIDER=mock

# OpenAI 配置
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_BASE_URL=https://api.openai.com/v1

# Ollama 配置（本地部署）
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2:7b

# 通义千问配置
QWEN_API_KEY=your-qwen-api-key-here
QWEN_MODEL=qwen-max

# Moonshot 配置
MOONSHOT_API_KEY=your-moonshot-api-key-here
MOONSHOT_MODEL=moonshot-v1-8k

# ============================================
# 🔧 向量化模型配置
# ============================================

# 嵌入模型选择
# 可选值：bge-m3, bge-large-zh, text2vec 等
EMBEDDING_MODEL=bge-m3

# 模型路径（本地模型）
BGE_M3_PATH=./models/bge-m3
BGE_RERANKER_PATH=./models/bge-reranker-v2

# HuggingFace 配置（如使用）
HUGGINGFACE_TOKEN=your-huggingface-token-here

# ============================================
# 📊 Dashboard 配置
# ============================================

DASHBOARD_ENABLED=true
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8000

# API 文档
API_DOCS_ENABLED=true
# SWAGGER_UI_URL=/docs
# REDOC_URL=/redocs

# ============================================
# 🔐 安全配置
# ============================================

# JWT Token 配置
JWT_SECRET_KEY=your-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# OAuth2 配置（可选）
OAUTH2_CLIENT_ID=your-oauth2-client-id
OAUTH2_CLIENT_SECRET=your-oauth2-client-secret

# CORS 配置
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
CORS_ALLOW_CREDENTIALS=true

# ============================================
# 🧠 智能路由配置 (v2.0 新增)
# ============================================

# 意图分析配置
INTENT_ANALYSIS_ENABLED=true
INTENT_CLASSIFIER_MODEL=jieba
# INTENT_CLASSIFIER_MODEL=ml

# 用户画像配置
USER_PROFILE_ENABLED=true
DEFAULT_USER_LEVEL=intermediate
# 可选：beginner, intermediate, expert

# CoT 思维链配置
COT_ENABLED=true
DEFAULT_COT_DEPTH=L2
# 可选：L1, L2, L3, L4

# 策略融合配置
STRATEGY_FUSION_ENABLED=true
EARLY_STOPPING_THRESHOLD=0.85
MAX_RETRIEVAL_ITERATIONS=5

# ============================================
# ⚙️ 性能优化配置
# ============================================

# 缓存配置
CACHE_ENABLED=true
CACHE_TTL=3600  # 秒

# 批处理配置
BATCH_SIZE=32
MAX_BATCH_SIZE=128

# 异步配置
ASYNC_ENABLED=true
MAX_CONCURRENT_REQUESTS=10

# ============================================
# 📈 监控与日志配置
# ============================================

# Prometheus 监控
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# Grafana 监控
GRAFANA_ENABLED=true
GRAFANA_HOST=localhost
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=necorag2026

# 日志配置
LOG_FORMAT=json
# LOG_FORMAT=text
LOG_FILE=./logs/necorag.log
LOG_MAX_BYTES=10485760  # 10MB
LOG_BACKUP_COUNT=5

# ============================================
# 🔌 插件扩展配置
# ============================================

PLUGINS_ENABLED=true
PLUGINS_DIR=./plugins
AUTO_LOAD_PLUGINS=true

# ============================================
# 📦 Docker 部署配置
# ============================================

# 如使用 Docker Compose 部署，以下配置会自动生效
# 参考：devops/.env.example

# Docker 网络配置
DOCKER_NETWORK_NAME=necorag-network

# 容器名称前缀
CONTAINER_NAME_PREFIX=necorag

# ============================================
# 🎯 功能开关配置
# ============================================

# 核心功能开关
ENABLE_PERCEPTION=true
ENABLE_MEMORY=true
ENABLE_RETRIEVAL=true
ENABLE_REFINEMENT=true
ENABLE_RESPONSE=true

# 增强功能开关
ENABLE_INTENT_ANALYSIS=true
ENABLE_DOMAIN_WEIGHT=true
ENABLE_KNOWLEDGE_EVOLUTION=true
ENABLE_MONITORING=true
ENABLE_SECURITY=true
ENABLE_ADAPTIVE_OPTIMIZATION=true

# ============================================
# 🧪 开发与测试配置
# ============================================

# 测试配置
TESTING_MODE=false
# TESTING_MODE=true

# Mock 数据
USE_MOCK_DATA=false
# USE_MOCK_DATA=true

# 调试工具
DEBUG_TOOLBAR=false
# DEBUG_TOOLBAR=true

# ============================================
# 🌏 区域化配置
# ============================================

DEFAULT_LANGUAGE=zh-CN
# DEFAULT_LANGUAGE=en-US

TIMEZONE=Asia/Shanghai

# 中文分词配置
CHINESE_SEGMENTATION=jieba

# ============================================
# 📝 其他配置
# ============================================

# 临时目录
TEMP_DIR=./tmp

# 数据目录
DATA_DIR=./data

# 模型目录
MODELS_DIR=./models

# 配置文件目录
CONFIGS_DIR=./configs
