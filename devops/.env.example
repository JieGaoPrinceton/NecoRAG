# ======================================
# NecoRAG Docker 部署环境变量
# 使用方式：复制为 .env 并修改
# cp .env.example .env
# ======================================

# --- 服务端口配置 ---
NECORAG_PORT=8000
REDIS_PORT=6379
QDRANT_HTTP_PORT=6334
QDRANT_GRPC_PORT=6333
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
OLLAMA_PORT=11434
GRAFANA_PORT=3000

# --- Neo4j 认证 ---
NEO4J_USER=neo4j
NEO4J_PASSWORD=necorag2026

# --- Grafana 认证 ---
GRAFANA_USER=admin
GRAFANA_PASSWORD=necorag2026

# --- LLM 配置 ---
LLM_PROVIDER=mock
# LLM_PROVIDER=ollama
# OLLAMA_MODEL=qwen2:7b

# --- NecoRAG 应用 ---
NECORAG_DEBUG=false
